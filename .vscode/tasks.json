{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Dev: Backend (@rozga/api)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"start:dev"
			],
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Dev: Frontend (@rozga/web)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Dev: Backend + Frontend",
			"dependsOn": [
				"Dev: Backend (@rozga/api)",
				"Dev: Frontend (@rozga/web)"
			],
			"dependsOrder": "parallel"
		}
	]
}